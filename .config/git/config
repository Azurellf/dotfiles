# .config/git/config

[core]
  editor = nvim
  pager = delta
  safecrlf = true

[color]
  ui = true

[interactive]
  diffFilter = delta --color-only

[merge]
  confilctStyle = zdiff3

[worktree]
  useRelativePaths = true

[delta]
  navigate = true
  dark = true
  line-numbers = true
  side-by-side = false

[push]
  autoSetupRemote = true # don't need git push -u
  default = current

[includeIf "gitdir:/D/Code/"]
    path = config_windows

[includeIf "gitdir:~/dotfiles/"]
    path = config_unix
